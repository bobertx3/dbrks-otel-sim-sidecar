DATABRICKS_HOST=https://e2-demo-field-eng.cloud.databricks.com
DATABRICKS_TOKEN=REPLACE_WITH_PAT

# Routing context
DATABRICKS_CATALOG=telemetry
DATABRICKS_SCHEMA=otel
OTEL_SERVICE_NAME=otel-local-mac-emitter

# Sidecar mode: route signals through local collectors (Fluent Bit, Telegraf, Alloy, Vector, OTel Collector)
# Set to false to send directly to Databricks (original behavior)
OTEL_SIDECAR_MODE=true

# Target tables (used in direct mode only; sidecar configs have their own table names)
OTEL_SPANS_TABLE=telemetry.otel.otel_spans_v2
OTEL_LOGS_TABLE=telemetry.otel.otel_logs_v2
OTEL_METRICS_TABLE=telemetry.otel.otel_metrics

# Optional: set to enable SQL verification queries from local notebook
DATABRICKS_WAREHOUSE_ID=

# Optional: Genie space used by Ask Genie tab
GENIE_SPACE_ID=
